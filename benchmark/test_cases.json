{
  "description": "Code intelligence benchmark for fastmcp codebase (~766 files). Tests navigation (where Grep excels) and semantic queries (where Glyphh excels) to measure real-world value.",
  "runtime_url": "http://localhost:8002",
  "org_id": "local-dev-org",
  "model_id": "code",
  "test_cases": [
    {
      "id": "nav_01",
      "type": "navigation",
      "query": "Find the OAuth authorization middleware",
      "expected_file": "src/fastmcp/server/middleware/authorization.py",
      "description": "Find a specific middleware by concept"
    },
    {
      "id": "nav_02",
      "type": "navigation",
      "query": "SSE transport connection handler",
      "expected_file": "src/fastmcp/client/transports/sse.py",
      "description": "Find SSE transport implementation"
    },
    {
      "id": "nav_03",
      "type": "navigation",
      "query": "tool injection middleware",
      "expected_file": "src/fastmcp/server/middleware/tool_injection.py",
      "description": "Find middleware that injects tools"
    },
    {
      "id": "nav_04",
      "type": "navigation",
      "query": "rate limiting middleware",
      "expected_file": "src/fastmcp/server/middleware/rate_limiting.py",
      "description": "Find rate limiter"
    },
    {
      "id": "nav_05",
      "type": "navigation",
      "query": "resource template URI matching",
      "expected_file": "src/fastmcp/resources/template.py",
      "description": "Find resource template matching logic"
    },
    {
      "id": "nav_06",
      "type": "navigation",
      "query": "error handling middleware for MCP protocol errors",
      "expected_file": "src/fastmcp/server/middleware/error_handling.py",
      "description": "Find error handling middleware"
    },
    {
      "id": "nav_07",
      "type": "navigation",
      "query": "caching middleware for MCP responses",
      "expected_file": "src/fastmcp/server/middleware/caching.py",
      "description": "Find response caching"
    },
    {
      "id": "nav_08",
      "type": "navigation",
      "query": "telemetry and logging instrumentation",
      "expected_file": "src/fastmcp/telemetry.py",
      "description": "Find telemetry module"
    },
    {
      "id": "nav_09",
      "type": "navigation",
      "query": "function tool decorator and registration",
      "expected_file": "src/fastmcp/tools/function_tool.py",
      "description": "Find tool registration"
    },
    {
      "id": "nav_10",
      "type": "navigation",
      "query": "server timing measurement middleware",
      "expected_file": "src/fastmcp/server/middleware/timing.py",
      "description": "Find timing middleware"
    },

    {
      "id": "blast_01",
      "type": "blast_radius",
      "query": "I'm about to edit src/fastmcp/server/auth/oauth_proxy/proxy.py — what other files might break?",
      "expected_files": [
        "src/fastmcp/server/auth/oidc_proxy.py",
        "src/fastmcp/server/auth/oauth_proxy/consent.py",
        "src/fastmcp/server/auth/oauth_proxy/models.py",
        "src/fastmcp/server/auth/auth.py"
      ],
      "min_expected": 2,
      "description": "Blast radius: OAuth proxy — high coupling"
    },
    {
      "id": "blast_02",
      "type": "blast_radius",
      "query": "I'm editing src/fastmcp/server/middleware/middleware.py — what else could be affected?",
      "expected_files": [
        "src/fastmcp/server/middleware/error_handling.py",
        "src/fastmcp/server/middleware/authorization.py",
        "src/fastmcp/server/middleware/rate_limiting.py",
        "src/fastmcp/server/middleware/caching.py",
        "src/fastmcp/server/middleware/timing.py",
        "src/fastmcp/server/middleware/tool_injection.py"
      ],
      "min_expected": 3,
      "description": "Blast radius: middleware base — many dependents"
    },
    {
      "id": "blast_03",
      "type": "blast_radius",
      "query": "What files are affected if I change src/fastmcp/client/transports/sse.py?",
      "expected_files": [
        "src/fastmcp/client/transports/streamable_http.py",
        "src/fastmcp/client/transports/stdio.py",
        "src/fastmcp/client/client.py"
      ],
      "min_expected": 2,
      "description": "Blast radius: SSE transport — sibling transports + client"
    },
    {
      "id": "blast_04",
      "type": "blast_radius",
      "query": "I need to refactor src/fastmcp/tools/base.py — what else will need changes?",
      "expected_files": [
        "src/fastmcp/tools/function_tool.py",
        "src/fastmcp/tools/tool_transform.py",
        "src/fastmcp/server/server.py"
      ],
      "min_expected": 2,
      "description": "Blast radius: tool base class — subclasses + server"
    },
    {
      "id": "blast_05",
      "type": "blast_radius",
      "query": "What breaks if I modify src/fastmcp/resources/template.py?",
      "expected_files": [
        "src/fastmcp/resources/function_resource.py",
        "src/fastmcp/resources/types.py",
        "src/fastmcp/server/server.py"
      ],
      "min_expected": 2,
      "description": "Blast radius: resource template — resource system"
    },

    {
      "id": "semantic_01",
      "type": "semantic",
      "query": "What handles webhook validation in this codebase?",
      "expected_files": [
        "src/fastmcp/server/auth/oauth_proxy/proxy.py",
        "src/fastmcp/server/auth/auth.py"
      ],
      "min_expected": 1,
      "description": "Semantic: find webhook validation (no exact string match)"
    },
    {
      "id": "semantic_02",
      "type": "semantic",
      "query": "How does the authentication middleware chain work?",
      "expected_files": [
        "src/fastmcp/server/middleware/authorization.py",
        "src/fastmcp/server/auth/auth.py",
        "src/fastmcp/server/middleware/middleware.py"
      ],
      "min_expected": 1,
      "description": "Semantic: auth middleware chain (conceptual)"
    },
    {
      "id": "semantic_03",
      "type": "semantic",
      "query": "What files deal with token refresh and expiry?",
      "expected_files": [
        "src/fastmcp/server/auth/oauth_proxy/proxy.py",
        "src/fastmcp/server/auth/oidc_proxy.py",
        "src/fastmcp/server/auth/oauth_proxy/models.py"
      ],
      "min_expected": 1,
      "description": "Semantic: token lifecycle (refresh, expiry)"
    },
    {
      "id": "semantic_04",
      "type": "semantic",
      "query": "What manages connection pooling and transport lifecycle?",
      "expected_files": [
        "src/fastmcp/client/transports/streamable_http.py",
        "src/fastmcp/client/transports/sse.py",
        "src/fastmcp/client/client.py"
      ],
      "min_expected": 1,
      "description": "Semantic: connection management (conceptual)"
    },
    {
      "id": "semantic_05",
      "type": "semantic",
      "query": "Where is request routing and dispatch handled?",
      "expected_files": [
        "src/fastmcp/server/server.py",
        "src/fastmcp/server/http.py",
        "src/fastmcp/server/middleware/middleware.py"
      ],
      "min_expected": 1,
      "description": "Semantic: request routing (conceptual)"
    }
  ]
}
